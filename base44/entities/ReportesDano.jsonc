{
  "name": "ReportesDano",
  "type": "object",
  "properties": {
    "tipo_estructura": {
      "type": "string",
      "enum": [
        "edificio_residencial",
        "hospital",
        "escuela",
        "iglesia",
        "comercio",
        "calle_via",
        "puente",
        "servicio_publico",
        "refugio",
        "otro"
      ]
    },
    "nombre_lugar": {
      "type": "string"
    },
    "nivel_dano": {
      "type": "string",
      "enum": [
        "leve",
        "moderado",
        "grave",
        "critico",
        "no_evaluado",
        "colapsado"
      ],
      "default": "no_evaluado"
    },
    "estado_acceso": {
      "type": "string",
      "enum": [
        "no_entrar",
        "solo_rescatistas",
        "entrada_limitada",
        "entrada_autorizada",
        "clausurado",
        "no_verificado"
      ],
      "default": "no_verificado"
    },
    "personas_atrapadas": {
      "type": "string",
      "enum": [
        "si",
        "no",
        "no_sabe",
        "voces",
        "posible"
      ]
    },
    "acceso_calle": {
      "type": "string",
      "enum": [
        "normal",
        "dificultad",
        "solo_peatonal",
        "bloqueada",
        "insegura",
        "no_sabe"
      ]
    },
    "acceso_vehiculos": {
      "type": "string",
      "enum": [
        "carros",
        "ambulancias",
        "camiones",
        "solo_motos",
        "bloqueado",
        "no_sabe"
      ]
    },
    "notas_acceso": {
      "type": "string"
    },
    "electricidad": {
      "type": "string",
      "enum": [
        "disponible",
        "no_disponible",
        "intermitente",
        "no_confirmado"
      ]
    },
    "agua": {
      "type": "string",
      "enum": [
        "disponible",
        "no_disponible",
        "intermitente",
        "no_confirmado"
      ]
    },
    "gas": {
      "type": "string",
      "enum": [
        "disponible",
        "no_disponible",
        "suspendido",
        "intermitente",
        "fuga_reportada",
        "no_confirmado"
      ]
    },
    "riesgo_gas": {
      "type": "boolean",
      "default": false
    },
    "riesgo_electrico": {
      "type": "boolean",
      "default": false
    },
    "riesgo_incendio": {
      "type": "boolean",
      "default": false
    },
    "riesgo_colapso": {
      "type": "boolean",
      "default": false
    },
    "descripcion": {
      "type": "string"
    },
    "direccion": {
      "type": "string"
    },
    "referencia": {
      "type": "string"
    },
    "ciudad": {
      "type": "string"
    },
    "estado_region": {
      "type": "string"
    },
    "lat": {
      "type": "number"
    },
    "lng": {
      "type": "number"
    },
    "geo_fuente": {
      "type": "string"
    },
    "foto_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contactos_acceso": {
      "type": "array",
      "description": "Personas autorizadas que pueden dar acceso al edificio para inspecci\u00f3n",
      "items": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "telefono": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "rol": {
            "type": "string"
          },
          "notas": {
            "type": "string"
          }
        }
      }
    },
    "prioridad": {
      "type": "string",
      "enum": [
        "normal",
        "alta",
        "critica"
      ],
      "default": "normal"
    },
    "estado_verificacion": {
      "type": "string",
      "enum": [
        "recibido",
        "verificado",
        "duplicado",
        "falso",
        "resuelto"
      ],
      "default": "recibido"
    },
    "nivel_verificacion": {
      "type": "string",
      "enum": [
        "sin_verificar",
        "comunidad",
        "institucional"
      ],
      "default": "sin_verificar"
    },
    "triage_estado": {
      "type": "string",
      "description": "Fase del triaje t\u00e9cnico: pendiente de clasificar, clasificado online, en cola de inspecci\u00f3n presencial, inspeccionado, descartado",
      "enum": [
        "pendiente_triage",
        "clasificado",
        "en_cola_inspeccion",
        "inspeccionado",
        "descartado"
      ],
      "default": "pendiente_triage"
    },
    "triage_riesgo": {
      "type": "string",
      "description": "Resultado del triaje r\u00e1pido online realizado por un especialista",
      "enum": [
        "sin_clasificar",
        "riesgo_colapso",
        "riesgo_moderado",
        "solo_estetico"
      ],
      "default": "sin_clasificar"
    },
    "triage_notas": {
      "type": "string",
      "description": "Notas t\u00e9cnicas del triaje r\u00e1pido"
    },
    "triage_por": {
      "type": "string",
      "description": "Nombre o email del especialista que hizo el triaje"
    },
    "triage_fecha": {
      "type": "string",
      "description": "Fecha ISO del triaje"
    },
    "requiere_inspeccion_presencial": {
      "type": "boolean",
      "description": "Marcado cuando el triaje determina que necesita visita t\u00e9cnica en persona",
      "default": false
    },
    "inspeccion_severidad": {
      "type": "string",
      "description": "Resultado de la inspecci\u00f3n presencial: nivel de severidad del da\u00f1o",
      "enum": [
        "sin_definir",
        "leve",
        "moderado",
        "grave",
        "critico"
      ],
      "default": "sin_definir"
    },
    "inspeccion_tipo_dano": {
      "type": "string",
      "description": "Tipo de da\u00f1o confirmado en la inspecci\u00f3n presencial",
      "enum": [
        "sin_definir",
        "estetico",
        "estructural",
        "ambos",
        "sin_danos"
      ],
      "default": "sin_definir"
    },
    "inspeccion_notas": {
      "type": "string",
      "description": "Informe t\u00e9cnico de la inspecci\u00f3n presencial"
    },
    "inspeccion_fotos": {
      "type": "array",
      "description": "Fotos tomadas durante la inspecci\u00f3n presencial",
      "items": {
        "type": "string"
      }
    },
    "inspeccion_detalle_fotos": {
      "type": "array",
      "description": "Detalle foto por foto de la inspecci\u00f3n presencial: cada foto con su \u00e1rea y nota t\u00e9cnica",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "area": {
            "type": "string"
          },
          "nota": {
            "type": "string"
          }
        }
      }
    },
    "inspeccion_pdf_url": {
      "type": "string",
      "description": "URL p\u00fablica del informe t\u00e9cnico de inspecci\u00f3n en PDF, descargable desde la ficha"
    },
    "inspeccion_pdf_fecha": {
      "type": "string",
      "description": "Fecha ISO en que se gener\u00f3 el PDF del informe de inspecci\u00f3n"
    },
    "inspeccion_fecha": {
      "type": "string",
      "description": "Fecha ISO de la inspecci\u00f3n presencial completada"
    },
    "inspeccion_por": {
      "type": "string",
      "description": "Nombre o email del especialista que hizo la inspecci\u00f3n presencial"
    },
    "inspeccion_estado_pendiente": {
      "type": "string",
      "description": "Por qu\u00e9 la inspecci\u00f3n sigue pendiente (cuando aplica)",
      "enum": [
        "ninguno",
        "sin_contacto",
        "acceso_no_autorizado",
        "zona_insegura",
        "reprogramada",
        "esperando_maquinaria",
        "otro"
      ],
      "default": "ninguno"
    },
    "inspeccion_motivo_pendiente": {
      "type": "string",
      "description": "Detalle libre del motivo por el que la inspecci\u00f3n est\u00e1 pendiente"
    },
    "voluntario_asignado_id": {
      "type": "string",
      "description": "ID del usuario voluntario/especialista asignado a la inspecci\u00f3n presencial"
    },
    "voluntario_asignado_nombre": {
      "type": "string"
    },
    "reportante_nombre": {
      "type": "string"
    },
    "reportante_telefono": {
      "type": "string"
    },
    "reportante_email": {
      "type": "string"
    },
    "fuente": {
      "type": "string",
      "default": "web_publica"
    }
  },
  "required": [
    "tipo_estructura",
    "ciudad",
    "estado_region"
  ]
}