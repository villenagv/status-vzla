{
  "name": "PerfilProfesional",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_nombre": {
      "type": "string"
    },
    "telefono_contacto": {
      "type": "string",
      "description": "Tel\u00e9fono de contacto del especialista"
    },
    "tipo_perfil": {
      "type": "string",
      "enum": [
        "voluntario",
        "ingeniero",
        "arquitecto"
      ],
      "default": "voluntario"
    },
    "profesion": {
      "type": "string",
      "description": "Profesi\u00f3n u ocupaci\u00f3n del voluntario/profesional"
    },
    "especialidad": {
      "type": "string"
    },
    "zona_apoyo": {
      "type": "string",
      "description": "Estado o zona donde puede apoyar"
    },
    "disponibilidad": {
      "type": "string",
      "enum": [
        "tiempo_completo",
        "medio_tiempo",
        "fines_semana",
        "bajo_demanda"
      ],
      "description": "Disponibilidad de tiempo del voluntario"
    },
    "tipo_apoyo": {
      "type": "array",
      "description": "Tipos de apoyo que puede ofrecer",
      "items": {
        "type": "string",
        "enum": [
          "revision_digital",
          "inspeccion_presencial",
          "coordinacion",
          "carga_informacion",
          "apoyo_comunitario",
          "apoyo_administrativo"
        ]
      }
    },
    "documentos_validacion": {
      "type": "array",
      "description": "Documentos opcionales para validar credenciales",
      "items": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string",
            "enum": [
              "titulo",
              "carnet",
              "certificacion",
              "identificacion",
              "otro"
            ]
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "institucion": {
      "type": "string"
    },
    "numero_colegio": {
      "type": "string"
    },
    "estado_aprobacion": {
      "type": "string",
      "enum": [
        "pendiente",
        "aprobado",
        "rechazado"
      ],
      "default": "pendiente"
    },
    "aprobado_por": {
      "type": "string"
    },
    "notas_admin": {
      "type": "string"
    },
    "completado": {
      "type": "boolean",
      "default": false
    },
    "foto_perfil_url": {
      "type": "string",
      "description": "Foto de perfil obligatoria del inspector/voluntario/arquitecto, para identificaci\u00f3n visual"
    },
    "token_foto_perfil": {
      "type": "string",
      "description": "Token privado individual para subir la foto de perfil sin necesidad de iniciar sesi\u00f3n"
    },
    "token_foto_perfil_usado": {
      "type": "boolean",
      "default": false,
      "description": "Si el token ya fue usado para subir la foto"
    },
    "tipo_credencial_solicitada": {
      "type": "string",
      "enum": [
        "titulo",
        "carnet",
        "certificacion",
        "identificacion",
        "otro"
      ],
      "description": "Tipo de documento/credencial adicional solicitado por el admin"
    },
    "token_credencial_adicional": {
      "type": "string",
      "description": "Token privado individual para subir una credencial adicional solicitada por el admin, sin necesidad de iniciar sesi\u00f3n"
    },
    "token_credencial_usado": {
      "type": "boolean",
      "default": false,
      "description": "Si el token de credencial adicional ya fue usado"
    }
  },
  "required": [
    "user_id",
    "tipo_perfil"
  ]
}